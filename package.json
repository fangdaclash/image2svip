{
  "name": "image2svip",
  "version": "1.0.0",
  "private": true,
  "description": "A local image generation UI inspired by OpenSvip.",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux",
    "build:apk": "npx cap sync && npx cap open android"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.image2svip.app",
    "productName": "image2svip",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "img/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "img/shua.svg",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "img/shua.svg",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "img/shua.svg",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
